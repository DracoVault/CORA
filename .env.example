# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@localhost:5432/cora
CORA_SCORER_MODE=nemo

# ── Nemotron Mini 4B (Tier 0 — NVIDIA) ──────────────────────────────────────
NVIDIA_NEMOTRON_MINI_API_KEY=your-nvidia-api-key

# ── Gemma 3n E4B (Tier 0 Fallback — NVIDIA) ─────────────────────────────────
NVIDIA_GEMMA_3N_API_KEY=your-nvidia-api-key

# ── Nemotron Nano 9B v2 (Tier 1 — NVIDIA) ───────────────────────────────────
NVIDIA_NEMOTRON_NANO_9B_API_KEY=your-nvidia-api-key

# ── Nemotron Nano 30B-A3B (Tier 2 — NVIDIA) ─────────────────────────────────
NVIDIA_NEMOTRON_NANO_30B_API_KEY=your-nvidia-api-key

# ── Nemotron 3 Super 120B (Tier 3 — NVIDIA) ─────────────────────────────────
NVIDIA_NEMOTRON_SUPER_API_KEY=your-nvidia-api-key

# ── Mistral Medium 3.5 128B (Tier 3 Fallback — NVIDIA) ──────────────────────
NVIDIA_MISTRAL_MEDIUM_API_KEY=your-nvidia-api-key

# ── Qwen3 Coder 480B (Tier 4 — NVIDIA) ──────────────────────────────────────
NVIDIA_QWEN3_CODER_API_KEY=your-nvidia-api-key

# ── Qwen3.5 397B (Tier 4 Fallback — NVIDIA) ─────────────────────────────────
NVIDIA_QWEN3_5_API_KEY=your-nvidia-api-key

# ── Prompt Optimizer (Nemotron Nano 30B-A3B — NVIDIA) ────────────────────────
NVIDIA_PROMPT_OPTIMIZER_API_KEY=your-nvidia-api-key
